{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/markgravity/claudy-registry/schema/plugin.schema.json",
  "title": "Claudy Plugin",
  "description": "Schema for a Claudy marketplace plugin",
  "type": "object",
  "required": ["id", "kind", "name", "description", "author", "tags", "iconSF", "featured", "version"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique plugin key in 'name@org' format (e.g. 'example-mcp@markgravity')",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?@[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "kind": {
      "type": "string",
      "description": "Plugin type",
      "enum": ["mcp", "skill", "command"]
    },
    "name": {
      "type": "string",
      "description": "Display name shown in the marketplace",
      "minLength": 2,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "description": "Short description of what the plugin does",
      "minLength": 10,
      "maxLength": 200
    },
    "author": {
      "type": "string",
      "description": "GitHub username of the plugin author"
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "iconSF": {
      "type": "string",
      "description": "SF Symbols icon name (e.g. 'gear', 'network')"
    },
    "featured": {
      "type": "boolean",
      "description": "Whether this plugin is featured in the marketplace"
    },
    "version": {
      "type": "string",
      "description": "Plugin version in semver format (e.g. '1.0.0')",
      "pattern": "^\d+\.\d+\.\d+$"
    },
    "homepageURL": {
      "type": "string",
      "description": "URL for the plugin's homepage or documentation",
      "format": "uri"
    },
    "gitURL": {
      "type": "string",
      "description": "Full git repository URL (e.g. 'https://github.com/owner/repo')",
      "format": "uri"
    },
    "gitBranch": {
      "type": "string",
      "description": "Branch to download from (required with gitURL if no gitTag)"
    },
    "gitTag": {
      "type": "string",
      "description": "Tag to download from (required with gitURL if no gitBranch)"
    },
    "gitPath": {
      "type": "string",
      "description": "Subdirectory within the repo to use as plugin root"
    },
    "mcpTransport": {
      "type": "string",
      "description": "MCP transport type (required for kind=mcp)",
      "enum": ["stdio", "http"]
    },
    "mcpInstallCommand": {
      "type": "string",
      "description": "Install command for stdio MCP servers (e.g. 'npx', 'uvx')"
    },
    "mcpInstallArgs": {
      "type": "array",
      "description": "Arguments for the install command",
      "items": {
        "type": "string"
      }
    },
    "mcpUrl": {
      "type": "string",
      "description": "URL for http MCP servers",
      "format": "uri"
    },
    "requiresEnvVars": {
      "type": "array",
      "description": "Environment variable names required by this plugin",
      "items": {
        "type": "string"
      }
    }
  },
  "if": {
    "properties": { "kind": { "const": "mcp" } },
    "required": ["kind"]
  },
  "then": {
    "required": ["mcpTransport"]
  },
  "not": {
    "anyOf": [
      { "required": ["installCount"] },
      { "required": ["averageRating"] },
      { "required": ["ratingCount"] },
      { "required": ["ratingSum"] }
    ]
  }
}
